<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raveena Sharma — Cybersecurity Engineer // Candidate Node</title>
<meta name="description" content="Raveena Sharma - Cybersecurity engineering student. CTF competitor, builder of a DLP platform and a tamper-resistant distributed storage system. Open to security engineering internships.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;800;900&family=Rajdhani:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#03050a;
    --bg-soft:#070c17;
    --panel:rgba(15,23,38,0.55);
    --panel-solid:#0c1422;
    --border:rgba(120,150,200,0.14);
    --border-hi:rgba(125,175,255,0.4);
    --blue:#3d7fff;
    --blue-bright:#7eb2ff;
    --red:#ff3355;
    --red-bright:#ff7088;
    --red-dim:#7a2233;
    --text:#dde4f1;
    --text-dim:#7e8ba3;
    --text-faint:#454f68;
    --f-display:'Orbitron', sans-serif;
    --f-head:'Rajdhani', sans-serif;
    --f-mono:'JetBrains Mono', monospace;
    --f-body:'Inter', sans-serif;
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  @media (prefers-reduced-motion: reduce){
    html{ scroll-behavior:auto; }
    *{ animation-duration:.01ms !important; animation-iteration-count:1 !important; transition-duration:.01ms !important; }
  }
  body{
    background:var(--bg); color:var(--text); font-family:var(--f-body); line-height:1.65;
    position:relative; overflow-x:hidden;
  }
  ::selection{ background:var(--red); color:#fff; }
  a{ color:inherit; text-decoration:none; }

  @media (pointer:fine){ html.has-cursor, html.has-cursor *{ cursor:none !important; } }

  /* ---------- Particle network background ---------- */
  #netCanvas{ position:fixed; inset:0; z-index:0; }
  .bg-fade{
    position:fixed; inset:0; z-index:0; pointer-events:none;
    background:radial-gradient(ellipse 90% 70% at 50% 0%, transparent 30%, var(--bg) 92%);
  }

  /* ---------- Custom cursor ---------- */
  .cursor-dot, .cursor-ring{ position:fixed; top:0; left:0; z-index:200; pointer-events:none; border-radius:50%; transform:translate(-50%,-50%); }
  .cursor-dot{ width:6px; height:6px; background:var(--blue-bright); box-shadow:0 0 8px var(--blue-bright); }
  .cursor-ring{ width:34px; height:34px; border:1px solid var(--border-hi); transition:width .2s ease, height .2s ease, border-color .2s ease, background .2s ease; }
  .cursor-ring.active{ width:54px; height:54px; border-color:var(--red); background:rgba(255,51,85,0.08); }
  @media (pointer:coarse){ .cursor-dot, .cursor-ring{ display:none; } }

  /* ---------- Scroll progress ---------- */
  .progress-bar{ position:fixed; top:0; left:0; height:2.5px; width:0%; z-index:90; background:linear-gradient(90deg, var(--blue), var(--red)); box-shadow:0 0 10px rgba(125,175,255,0.6); }

  /* ---------- Nav ---------- */
  .side-nav{ position:fixed; top:0; left:0; height:100vh; width:60px; z-index:50; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:26px; }
  .nav-track{ position:absolute; top:14%; bottom:14%; left:50%; width:1px; background:var(--border); transform:translateX(-50%); }
  .nav-fill{ position:absolute; top:0; left:0; width:100%; height:0%; background:linear-gradient(var(--blue), var(--red)); transition:height .15s linear; }
  .side-nav a{
    position:relative; writing-mode:vertical-rl; text-orientation:mixed; font-family:var(--f-mono); font-size:10.5px;
    letter-spacing:.12em; color:var(--text-faint); display:flex; align-items:center; gap:9px; padding:5px 0; transition:color .25s ease;
  }
  .side-nav a .dot{ width:5px; height:5px; border-radius:50%; background:var(--text-faint); transition:background .25s ease, box-shadow .25s ease, transform .25s ease; }
  .side-nav a:hover{ color:var(--blue-bright); }
  .side-nav a.active{ color:var(--red-bright); }
  .side-nav a.active .dot{ background:var(--red); box-shadow:0 0 10px var(--red); transform:scale(1.4); }

  .mobile-nav{ display:none; }
  main, header.hero{ margin-left:60px; position:relative; z-index:2; }
  @media (max-width:860px){
    .side-nav{ display:none; }
    main, header.hero{ margin-left:0; }
    .mobile-nav{
      display:flex; position:fixed; bottom:0; left:0; right:0; z-index:50;
      background:rgba(5,8,14,0.92); backdrop-filter:blur(10px); border-top:1px solid var(--border);
      overflow-x:auto; padding:10px 14px; gap:18px;
    }
    .mobile-nav a{ font-family:var(--f-mono); font-size:10px; color:var(--text-faint); white-space:nowrap; letter-spacing:.05em; }
    .mobile-nav a.active{ color:var(--red-bright); }
    body{ padding-bottom:52px; }
  }

  .section{ position:relative; z-index:2; padding:120px 6vw 80px; max-width:1180px; }
  @media (max-width:860px){ .section{ padding:90px 6vw 60px; } }

  .eyebrow{ font-family:var(--f-mono); font-size:11.5px; letter-spacing:.2em; color:var(--blue-bright); display:flex; align-items:center; gap:10px; margin-bottom:18px; }
  .eyebrow::before{ content:''; width:22px; height:1px; background:var(--blue-bright); }
  h2.title{ font-family:var(--f-head); font-weight:700; font-size:clamp(28px,4vw,44px); color:#f2f6fc; margin-bottom:36px; }

  .reveal{ opacity:0; transform:translateY(22px); transition:opacity .7s cubic-bezier(.2,.7,.3,1), transform .7s cubic-bezier(.2,.7,.3,1); }
  .reveal.in{ opacity:1; transform:translateY(0); }

  /* ---------- Glass panel w/ spotlight + tilt ---------- */
  .panel{
    position:relative; border:1px solid var(--border); background:var(--panel); backdrop-filter:blur(14px);
    padding:24px; overflow:hidden; transform-style:preserve-3d; will-change:transform;
    transition:border-color .25s ease, box-shadow .25s ease;
  }
  .panel::before{ content:''; position:absolute; inset:0; padding:1px; border-radius:inherit; pointer-events:none;
    background:linear-gradient(135deg, rgba(125,175,255,0.25), transparent 40%, rgba(255,51,85,0.18));
    -webkit-mask:linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite:xor; mask-composite:exclude; opacity:.6;
  }
  .panel:hover{ border-color:var(--border-hi); box-shadow:0 12px 32px rgba(0,0,0,0.4); }
  .panel .spot{ position:absolute; inset:0; opacity:0; transition:opacity .35s ease; pointer-events:none;
    background:radial-gradient(260px circle at var(--mx,50%) var(--my,50%), rgba(125,175,255,0.16), transparent 70%); }
  .panel:hover .spot{ opacity:1; }

  /* ================= HERO ================= */
  header.hero{ min-height:100vh; display:flex; align-items:center; padding:90px 6vw 60px; }
  .hero-grid{ display:grid; grid-template-columns:1.1fr 0.9fr; gap:30px; align-items:center; width:100%; }
  @media (max-width:980px){ .hero-grid{ grid-template-columns:1fr; } .hero-radar-wrap{ display:none; } }

  .hero-tag{ font-family:var(--f-mono); font-size:12px; color:var(--text-dim); letter-spacing:.18em; margin-bottom:22px; display:flex; align-items:center; gap:8px; }
  .pulse-dot{ width:7px; height:7px; border-radius:50%; background:var(--red); box-shadow:0 0 10px var(--red); animation:pulse 1.6s ease-in-out infinite; }
  @keyframes pulse{ 0%,100%{ opacity:1; } 50%{ opacity:.3; } }

  .hero-name{ font-family:var(--f-display); font-weight:900; font-size:clamp(36px,7vw,78px); line-height:1.04; color:#f4f8ff; }
  .glitch{ position:relative; display:inline-block; color:var(--blue-bright); }
  .glitch::before, .glitch::after{
    content:attr(data-text); position:absolute; top:0; left:0; width:100%; opacity:0; overflow:hidden;
  }
  .glitch:hover::before{ color:var(--red); transform:translate(-3px,-1px); opacity:.85; animation:glitchShift .3s steps(2,end) infinite; }
  .glitch:hover::after{ color:var(--blue-bright); transform:translate(3px,1px); opacity:.85; animation:glitchShift .3s steps(2,end) infinite reverse; }
  @keyframes glitchShift{ 0%{ clip-path:inset(0 0 80% 0); } 50%{ clip-path:inset(40% 0 35% 0); } 100%{ clip-path:inset(75% 0 0 0); } }

  .hero-role{ font-family:var(--f-mono); font-size:clamp(14px,2vw,18px); color:var(--red-bright); margin-top:18px; min-height:1.4em; }
  .hero-role .cursor{ display:inline-block; width:9px; background:var(--red-bright); margin-left:2px; animation:blink 1s step-end infinite; }
  @keyframes blink{ 50%{ opacity:0; } }

  .hero-desc{ max-width:560px; color:var(--text-dim); margin-top:22px; font-size:15.5px; }

  .hero-actions{ display:flex; flex-wrap:wrap; gap:14px; margin-top:36px; }
  .btn{
    position:relative; font-family:var(--f-mono); font-size:13px; letter-spacing:.04em; padding:13px 22px;
    border:1px solid var(--border-hi); color:var(--text); background:transparent; cursor:pointer;
    transition:color .2s ease, box-shadow .2s ease; display:inline-flex; align-items:center; gap:8px; overflow:hidden;
  }
  .btn:hover{ color:#fff; box-shadow:0 0 22px rgba(61,127,255,0.3); }
  .btn.primary{ background:linear-gradient(120deg, var(--blue), #5a6dff); border-color:transparent; color:#06101f; font-weight:600; }
  .btn.primary:hover{ box-shadow:0 0 26px rgba(61,127,255,0.5); }
  .btn.danger:hover{ box-shadow:0 0 22px rgba(255,51,85,0.35); border-color:var(--red); }

  .stat-row{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-top:38px; max-width:480px; }
  .stat{ border-left:2px solid var(--blue); padding:4px 0 4px 14px; }
  .stat .num{ font-family:var(--f-display); font-size:26px; color:#fff; font-weight:800; }
  .stat .lbl{ font-family:var(--f-mono); font-size:9.5px; color:var(--text-faint); letter-spacing:.08em; margin-top:4px; }

  /* hero radar */
  .hero-radar-wrap{ display:flex; align-items:center; justify-content:center; }
  .radar{ position:relative; width:min(320px,26vw); aspect-ratio:1/1; min-width:220px; border-radius:50%; border:1px solid var(--border-hi);
    background:radial-gradient(circle, rgba(61,127,255,0.08), transparent 72%); }
  .radar-rings{ position:absolute; inset:16%; border:1px solid var(--border); border-radius:50%; }
  .radar-rings::before{ content:''; position:absolute; inset:22%; border:1px solid var(--border); border-radius:50%; }
  .radar-sweep{ position:absolute; inset:0; border-radius:50%; overflow:hidden;
    background:conic-gradient(from 0deg, rgba(255,51,85,0.4), transparent 28%); animation:sweep 4s linear infinite; mix-blend-mode:screen; }
  @keyframes sweep{ to{ transform:rotate(360deg); } }
  .radar-core{ position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:50px; height:50px; border-radius:50%;
    border:1px solid var(--border-hi); background:var(--bg); color:var(--blue-bright); display:flex; align-items:center; justify-content:center; }
  .blip{ position:absolute; top:var(--by); left:var(--bx); width:7px; height:7px; border-radius:50%; background:var(--blue-bright);
    box-shadow:0 0 10px var(--blue-bright); animation:blipPulse 2.6s ease-in-out infinite; animation-delay:var(--bd,0s); }
  .blip::after{ content:attr(data-label); position:absolute; top:-17px; left:50%; transform:translateX(-50%);
    font-family:var(--f-mono); font-size:9px; letter-spacing:.06em; color:var(--text-faint); white-space:nowrap; }
  @keyframes blipPulse{ 0%,100%{ opacity:.4; transform:scale(.85); } 50%{ opacity:1; transform:scale(1.2); } }

  /* ================= THREAT MODEL ================= */
  .about-grid{ display:grid; grid-template-columns:1.1fr 1fr; gap:48px; align-items:start; }
  @media (max-width:860px){ .about-grid{ grid-template-columns:1fr; } }
  .about-copy p{ color:var(--text-dim); font-size:16px; margin-bottom:16px; max-width:52ch; }
  .about-copy strong{ color:var(--text); font-weight:600; }

  .surface-card .row-title{ font-family:var(--f-mono); font-size:11px; letter-spacing:.1em; color:var(--text-dim); margin:18px 0 10px; }
  .surface-card .row-title.hardened{ color:var(--blue-bright); }
  .surface-card .row-title.open{ color:var(--red-bright); }
  .surface-card ul{ list-style:none; }
  .surface-card li{ font-size:13.5px; color:var(--text); padding:6px 0 6px 16px; position:relative; border-bottom:1px dashed var(--border); }
  .surface-card li::before{ content:'›'; position:absolute; left:0; color:var(--text-faint); }
  .surface-card .target-line{ font-family:var(--f-mono); font-size:11px; color:var(--text-faint); letter-spacing:.08em; margin-bottom:4px; }
  .surface-card .target-name{ font-family:var(--f-head); font-size:21px; color:#fff; font-weight:700; }
  .objective-box{ margin-top:18px; padding:14px; border-left:2px solid var(--red); background:rgba(255,51,85,0.06); font-size:13px; color:var(--text); }
  .objective-box .lbl{ font-family:var(--f-mono); font-size:10px; color:var(--red-bright); letter-spacing:.1em; display:block; margin-bottom:6px; }

  /* ================= ARSENAL / RADAR CHART ================= */
  .arsenal-top{ display:grid; grid-template-columns:0.85fr 1.15fr; gap:40px; align-items:center; margin-bottom:46px; }
  @media (max-width:900px){ .arsenal-top{ grid-template-columns:1fr; } }
  .skill-chart{ display:flex; justify-content:center; }
  .skill-chart svg{ width:100%; max-width:380px; height:auto; }
  .chart-poly{ fill:rgba(61,127,255,0.18); stroke:var(--blue-bright); stroke-width:1.6; opacity:0; transform:scale(.4); transform-origin:200px 200px; transition:opacity .8s ease, transform .8s cubic-bezier(.2,.8,.2,1); }
  .skill-chart.in .chart-poly{ opacity:1; transform:scale(1); }
  .chart-axis{ stroke:var(--border); stroke-width:1; }
  .chart-label{ font-family:var(--f-mono); font-size:10.5px; fill:var(--text-dim); }
  .chart-ring{ fill:none; stroke:var(--border); stroke-width:1; }

  .arsenal-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:18px; }
  @media (max-width:760px){ .arsenal-grid{ grid-template-columns:1fr; } }
  .arsenal-card h3{ font-family:var(--f-mono); font-size:13px; letter-spacing:.1em; color:var(--blue-bright); margin-bottom:14px; }
  .chip-row{ display:flex; flex-wrap:wrap; gap:8px; position:relative; z-index:1; }
  .chip{ font-family:var(--f-mono); font-size:12px; color:var(--text-dim); border:1px solid var(--border); padding:6px 10px; transition:border-color .2s ease, color .2s ease; }
  .chip:hover{ border-color:var(--blue-bright); color:#fff; }

  .cert-strip{ margin-top:36px; }
  .cert-strip .row-title{ font-family:var(--f-mono); font-size:11px; color:var(--text-faint); letter-spacing:.1em; margin-bottom:14px; }
  .cert-list{ display:flex; flex-wrap:wrap; gap:10px; position:relative; z-index:1; }
  .cert-pill{ font-family:var(--f-mono); font-size:11.5px; padding:9px 14px; border:1px solid var(--border); color:var(--text-dim); display:flex; align-items:center; gap:8px; }
  .cert-pill::before{ content:''; width:6px; height:6px; background:var(--red); }

  /* ================= OPERATIONS ================= */
  .ops-grid{ display:grid; grid-template-columns:1.2fr 1fr; gap:48px; align-items:start; }
  @media (max-width:900px){ .ops-grid{ grid-template-columns:1fr; } }
  .timeline{ position:relative; margin-left:6px; padding-left:26px; }
  .timeline::before{ content:''; position:absolute; left:0; top:4px; bottom:4px; width:1px; background:var(--border); }
  .timeline-fill{ position:absolute; left:0; top:4px; width:1px; height:0%; background:linear-gradient(var(--red),var(--blue)); transition:height 1.1s cubic-bezier(.2,.7,.3,1); }
  .tl-item{ position:relative; padding-bottom:30px; }
  .tl-item:last-child{ padding-bottom:0; }
  .tl-item::before{ content:''; position:absolute; left:-31px; top:4px; width:10px; height:10px; background:var(--bg); border:2px solid var(--blue); border-radius:50%; }
  .tl-item.current::before{ border-color:var(--red); box-shadow:0 0 10px var(--red); }
  .tl-date{ font-family:var(--f-mono); font-size:11px; color:var(--text-faint); letter-spacing:.05em; }
  .tl-role{ font-family:var(--f-head); font-size:18px; color:#eef3fa; font-weight:600; margin-top:4px; }
  .tl-org{ font-size:13px; color:var(--text-dim); margin-top:2px; }

  .log-panel{ font-family:var(--f-mono); font-size:13px; position:relative; z-index:1; }
  .log-row{ display:flex; justify-content:space-between; gap:12px; padding:10px 0; border-bottom:1px solid var(--border); }
  .log-row:last-child{ border-bottom:none; }
  .log-rank{ color:var(--red-bright); white-space:nowrap; }
  .log-rank.neutral{ color:var(--text-faint); }

  /* ================= MISSIONS ================= */
  .mission-list{ display:flex; flex-direction:column; gap:18px; }
  .mission{ display:grid; grid-template-columns:90px 1fr; gap:22px; padding:28px; }
  @media (max-width:700px){ .mission{ grid-template-columns:1fr; gap:10px; } }
  .mission .mid{ font-family:var(--f-mono); font-size:11px; color:var(--text-faint); letter-spacing:.06em; position:relative; z-index:1; }
  .mission .mid .num{ display:block; font-family:var(--f-display); font-size:30px; color:rgba(125,175,255,0.4); margin-top:6px; }
  .mission h3{ font-family:var(--f-head); font-size:21px; color:#fff; font-weight:700; margin-bottom:10px; position:relative; z-index:1; }
  .mission p{ color:var(--text-dim); font-size:14.5px; max-width:62ch; position:relative; z-index:1; }
  .mission .tags{ display:flex; flex-wrap:wrap; gap:8px; margin-top:14px; position:relative; z-index:1; }
  .mission .tags span{ font-family:var(--f-mono); font-size:11px; color:var(--blue-bright); border:1px solid rgba(61,127,255,0.4); padding:4px 9px; }
  .mission .repo-link{ font-family:var(--f-mono); font-size:12px; color:var(--red-bright); margin-top:16px; display:inline-flex; align-items:center; gap:6px; position:relative; z-index:1; }
  .mission .repo-link:hover{ text-decoration:underline; }

  /* ================= CONTACT / TERMINAL ================= */
  .contact-grid{ display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:start; }
  @media (max-width:900px){ .contact-grid{ grid-template-columns:1fr; } }

  .term-window{ border:1px solid var(--border-hi); background:rgba(4,7,13,0.8); backdrop-filter:blur(10px); position:relative; overflow:hidden; }
  .term-window::before{ content:''; position:absolute; inset:0; pointer-events:none; opacity:.5;
    background:repeating-linear-gradient(0deg, rgba(125,175,255,0.025) 0 2px, transparent 2px 4px); }
  .term-bar{ display:flex; align-items:center; gap:8px; padding:10px 14px; border-bottom:1px solid var(--border); font-family:var(--f-mono); font-size:11px; color:var(--text-faint); }
  .term-dot{ width:9px; height:9px; border-radius:50%; }
  .term-dot.r{ background:var(--red); } .term-dot.y{ background:#ffbd2e; } .term-dot.g{ background:var(--blue); }
  .term-body{ font-family:var(--f-mono); font-size:13px; padding:16px; height:320px; overflow-y:auto; color:var(--blue-bright); position:relative; }
  .term-line{ margin-bottom:6px; white-space:pre-wrap; word-break:break-word; }
  .term-line.dim{ color:var(--text-dim); }
  .term-line.warn{ color:var(--red-bright); }
  .term-line.hi{ color:#fff; }
  .term-input-row{ display:flex; align-items:center; gap:8px; border-top:1px solid var(--border); padding:10px 14px; position:relative; }
  .term-input-row .prompt{ color:var(--red-bright); font-family:var(--f-mono); font-size:13px; }
  .term-input-row input{ flex:1; background:transparent; border:none; outline:none; color:var(--blue-bright); font-family:var(--f-mono); font-size:13px; }
  .term-hint{ font-family:var(--f-mono); font-size:11px; color:var(--text-faint); margin-top:10px; }

  .contact-direct h3{ font-family:var(--f-mono); font-size:12px; letter-spacing:.1em; color:var(--text-dim); margin-bottom:18px; }
  .contact-line{ display:flex; justify-content:space-between; align-items:center; padding:14px 0; border-bottom:1px solid var(--border); font-size:14.5px; position:relative; z-index:1; }
  .contact-line .k{ color:var(--text-faint); font-family:var(--f-mono); font-size:12px; }
  .contact-line .v:hover{ color:var(--blue-bright); }
  .status-badge{ margin-top:24px; padding:14px; border:1px solid rgba(61,127,255,0.3); background:rgba(61,127,255,0.06); font-family:var(--f-mono); font-size:12.5px; color:var(--blue-bright); position:relative; z-index:1; }

  footer{ position:relative; z-index:2; padding:40px 6vw 60px; font-family:var(--f-mono); font-size:11.5px; color:var(--text-faint);
    display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px; border-top:1px solid var(--border); }

  a:focus-visible, button:focus-visible, input:focus-visible{ outline:2px solid var(--blue-bright); outline-offset:2px; }
</style>
</head>
<body>

<canvas id="netCanvas"></canvas>
<div class="bg-fade"></div>
<div class="progress-bar" id="progressBar"></div>
<div class="cursor-ring" id="cursorRing"></div>
<div class="cursor-dot" id="cursorDot"></div>

<nav class="side-nav" id="sideNav">
  <div class="nav-track"><div class="nav-fill" id="navFill"></div></div>
  <a href="#identity" data-sec="identity"><span class="dot"></span>01 IDENTITY</a>
  <a href="#threat-model" data-sec="threat-model"><span class="dot"></span>02 THREAT MODEL</a>
