<script>
  var REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var COARSE = window.matchMedia('(pointer: coarse)').matches;

  // ---------- Particle network background ----------
  (function particles(){
    var canvas = document.getElementById('netCanvas');
    var ctx = canvas.getContext('2d');
    var w, h, particlesArr;
    var mouse = { x:-9999, y:-9999 };

    function resize(){
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
      var count = Math.max(36, Math.min(95, Math.floor((w*h)/22000)));
      particlesArr = [];
      for(var i=0;i<count;i++){
        particlesArr.push({
          x: Math.random()*w, y: Math.random()*h,
          vx: (Math.random()-0.5)*0.35, vy: (Math.random()-0.5)*0.35,
          r: Math.random()*1.6+0.8,
          red: Math.random() < 0.14
        });
      }
    }
    resize();
    window.addEventListener('resize', resize);
    window.addEventListener('mousemove', function(e){ mouse.x = e.clientX; mouse.y = e.clientY; });
    window.addEventListener('mouseleave', function(){ mouse.x = -9999; mouse.y = -9999; });

    var linkDist = 130, mouseDist = 150;

    function frame(){
      ctx.clearRect(0,0,w,h);
      for(var i=0;i<particlesArr.length;i++){
        var p = particlesArr[i];
        p.x += p.vx; p.y += p.vy;
        if(p.x < 0 || p.x > w) p.vx *= -1;
        if(p.y < 0 || p.y > h) p.vy *= -1;

        var dxm = p.x - mouse.x, dym = p.y - mouse.y;
        var dm = Math.sqrt(dxm*dxm + dym*dym);
        if(dm < mouseDist){
          var force = (mouseDist - dm) / mouseDist;
          p.x += (dxm/dm) * force * 1.1;
          p.y += (dym/dm) * force * 1.1;
        }
      }
      for(var i=0;i<particlesArr.length;i++){
        for(var j=i+1;j<particlesArr.length;j++){
          var a = particlesArr[i], b = particlesArr[j];
          var dx = a.x-b.x, dy = a.y-b.y;
          var d = Math.sqrt(dx*dx+dy*dy);
          if(d < linkDist){
            var op = (1 - d/linkDist) * 0.5;
            var isRed = a.red || b.red;
            ctx.strokeStyle = isRed ? 'rgba(255,51,85,' + op*0.6 + ')' : 'rgba(125,175,255,' + op + ')';
            ctx.lineWidth = 0.6;
            ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke();
          }
        }
      }
      for(var i=0;i<particlesArr.length;i++){
        var p = particlesArr[i];
        ctx.beginPath();
        ctx.fillStyle = p.red ? 'rgba(255,90,110,0.85)' : 'rgba(125,175,255,0.85)';
        ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
        ctx.fill();
      }
      requestAnimationFrame(frame);
    }

    if(REDUCED){
      frame(); // draw a single static-ish layout, no continuous loop needed but harmless lightweight
    } else {
      requestAnimationFrame(frame);
    }
  })();

  // ---------- Custom cursor ----------
  (function cursor(){
    if(COARSE || REDUCED) return;
    document.documentElement.classList.add('has-cursor');
    var dot = document.getElementById('cursorDot');
    var ring = document.getElementById('cursorRing');
    var tx=0, ty=0, rx=0, ry=0;
    window.addEventListener('mousemove', function(e){ tx=e.clientX; ty=e.clientY; dot.style.left=tx+'px'; dot.style.top=ty+'px'; });
    function loop(){
      rx += (tx-rx)*0.18; ry += (ty-ry)*0.18;
      ring.style.left = rx+'px'; ring.style.top = ry+'px';
      requestAnimationFrame(loop);
    }
    loop();
    document.querySelectorAll('a, button, input, .panel, .chip').forEach(function(el){
      el.addEventListener('mouseenter', function(){ ring.classList.add('active'); });
      el.addEventListener('mouseleave', function(){ ring.classList.remove('active'); });
    });
  })();

  // ---------- Scroll progress + nav fill ----------
  (function progress(){
    var bar = document.getElementById('progressBar');
    var fill = document.getElementById('navFill');
    function update(){
      var h = document.documentElement;
      var pct = (h.scrollTop) / (h.scrollHeight - h.clientHeight) * 100;
      bar.style.width = pct + '%';
      if(fill) fill.style.height = pct + '%';
    }
    window.addEventListener('scroll', update, { passive:true });
    update();
  })();

  // ---------- Hero role typing ----------
  (function typeRole(){
    var roles = ['Cybersecurity Engineer (in training)', 'CTF Competitor', 'Full-Stack Developer', 'Security-First Builder', 'SOC / Blue Team — track'];
    var el = document.getElementById('roleType');
    if(REDUCED){ el.textContent = roles[0]; return; }
    var r=0, c=0, deleting=false;
    function tick(){
      var word = roles[r];
      if(!deleting){ c++; el.textContent = word.slice(0,c); if(c===word.length){ deleting=true; setTimeout(tick,1400); return; } }
      else{ c--; el.textContent = word.slice(0,c); if(c===0){ deleting=false; r=(r+1)%roles.length; } }
      setTimeout(tick, deleting?28:55);
    }
    tick();
  })();

  // ---------- Count-up stats ----------
  (function countUp(){
    document.querySelectorAll('[data-count]').forEach(function(el){
      var target = parseFloat(el.dataset.count);
      var isDecimal = el.dataset.count.indexOf('.') > -1;
      var done = false;
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting && !done){
            done = true;
            if(REDUCED){ el.textContent = el.dataset.count; return; }
            var start = null, duration = 1300;
            function step(ts){
              if(!start) start = ts;
              var p = Math.min((ts-start)/duration, 1);
              var val = target * p;
              el.textContent = isDecimal ? val.toFixed(1) : Math.floor(val);
              if(p < 1) requestAnimationFrame(step); else el.textContent = el.dataset.count;
            }
            requestAnimationFrame(step);
          }
        });
      }, { threshold:0.6 });
      io.observe(el);
    });
  })();

  // ---------- Scroll reveal ----------
  (function reveal(){
    var items = document.querySelectorAll('.reveal');
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold:0.15 });
    items.forEach(function(i){ io.observe(i); });
  })();

  // ---------- Skill radar chart reveal ----------
  (function skillChart(){
    var el = document.getElementById('skillChart');
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ el.classList.add('in'); io.unobserve(el); } });
    }, { threshold:0.3 });
    io.observe(el);
  })();

  // ---------- Timeline fill ----------
  (function timelineFill(){
    var wrap = document.getElementById('timelineWrap');
    var fill = document.getElementById('timelineFill');
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ fill.style.height = '100%'; io.unobserve(wrap); } });
    }, { threshold:0.2 });
    io.observe(wrap);
  })();

  // ---------- Panel spotlight + tilt ----------
  (function panelFX(){
    if(REDUCED || COARSE) return;
    document.querySelectorAll('.panel').forEach(function(panel){
      var spot = panel.querySelector('.spot');
      panel.addEventListener('mousemove', function(e){
        var r = panel.getBoundingClientRect();
        var x = e.clientX - r.left, y = e.clientY - r.top;
        var px = (x/r.width)*100, py = (y/r.height)*100;
        if(spot){ spot.style.setProperty('--mx', px+'%'); spot.style.setProperty('--my', py+'%'); }
        var rx = ((py/100)-0.5)*-4, ry = ((px/100)-0.5)*4;
        panel.style.transform = 'perspective(700px) rotateX('+rx+'deg) rotateY('+ry+'deg)';
      });
      panel.addEventListener('mouseleave', function(){ panel.style.transform = 'perspective(700px) rotateX(0deg) rotateY(0deg)'; });
    });
  })();

  // ---------- Nav active state ----------
  (function navActive(){
    var sections = document.querySelectorAll('.section, header.hero');
    var navLinks = document.querySelectorAll('.side-nav a, .mobile-nav a');
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){
          var id = e.target.id;
          navLinks.forEach(function(l){ l.classList.toggle('active', l.dataset.sec === id); });
        }
      });
    }, { threshold:0.4 });
    sections.forEach(function(s){ io.observe(s); });
  })();

